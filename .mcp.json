{
  "name": "content-registry-mcp",
  "description": "Content Registry MCP server. Tools: register content, verify content, search registry. Built by MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "register_content",
      "description": "Register content with a cryptographic hash and timestamp. Returns a registration ID for future verification.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "content_type": {
            "type": "string"
          },
          "tags": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "content",
          "author"
        ]
      }
    },
    {
      "name": "verify_content",
      "description": "Verify registered content integrity by comparing hashes. Provide content + registration_id or expected_hash.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "registration_id": {
            "type": "string"
          },
          "expected_hash": {
            "type": "string"
          }
        },
        "required": [
          "content"
        ]
      }
    },
    {
      "name": "search_registry",
      "description": "Search the registry by title/tag query, hash, author, content type, or status.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "content_hash": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "content_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_provenance_chain",
      "description": "Get the full provenance trail for a registered content item - all events from registration through any modifications or verifications.",
      "parameters": {
        "type": "object",
        "properties": {
          "registration_id": {
            "type": "string"
          }
        },
        "required": [
          "registration_id"
        ]
      }
    },
    {
      "name": "revoke_registration",
      "description": "Revoke a content registration. Content record is preserved but marked as revoked.",
      "parameters": {
        "type": "object",
        "properties": {
          "registration_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "revoked_by": {
            "type": "string"
          }
        },
        "required": [
          "registration_id",
          "reason",
          "revoked_by"
        ]
      }
    }
  ]
}